PORT=5000
JWT_SECRET=your_jwt_secret_here

# SQLite always persists to ./database.sqlite in this folder (config/database.js
# hardcodes the path). This var is not read by the app — leave it unset.
DATABASE_URL=


# Cloudinary (optional — driver photo uploads fail without these)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin service account JSON path (relative to backend folder)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/drivermonitoringsystem-7948e-firebase-adminsdk-fbsvc-c513fed8b5.json
FIREBASE_DATABASE_URL=
